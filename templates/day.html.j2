<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>daily — {{ date_str }}</title>
<style>
  body { font-family: Georgia, serif; max-width: 780px; margin: 2rem auto; padding: 0 1.25rem; color: #1a1a1a; line-height: 1.65; }
  nav { margin-bottom: 2rem; font-size: 0.875rem; color: #777; }
  nav a { color: #555; text-decoration: none; }
  nav a:hover { text-decoration: underline; }
  h1 { font-size: 1.75rem; letter-spacing: -0.5px; margin: 0 0 0.2rem; }
  .date { color: #999; font-size: 0.875rem; margin-bottom: 2.5rem; }
  .item { display: flex; gap: 1rem; margin-bottom: 0; padding: 1.25rem 0; border-bottom: 1px solid #e8e8e8; }
  .item:first-of-type { border-top: 1px solid #e8e8e8; }
  .rank { font-size: 0.8rem; color: #ccc; min-width: 2rem; padding-top: 0.2rem; text-align: right; flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 0.15rem; }
  .rank-pos { font-size: 0.8rem; color: #ccc; }
  .rank-score { font-size: 0.72rem; color: #bbb; font-variant-numeric: tabular-nums; }
  .item-body { flex: 1; min-width: 0; }
  .item-body h2 { font-size: 1rem; margin: 0 0 0.2rem; line-height: 1.4; }
  .item-body h2 a { color: #1a1a1a; text-decoration: none; }
  .item-body h2 a:hover { text-decoration: underline; }
  .meta { font-size: 0.78rem; color: #aaa; margin-bottom: 0; }
  .meta .source { font-weight: bold; color: #888; }
  .meta a { color: #aaa; text-decoration: none; }
  .meta a:hover { text-decoration: underline; }
  details { margin-top: 0.6rem; }
  summary { font-size: 0.85rem; color: #888; cursor: pointer; list-style: none; }
  summary::-webkit-details-marker { display: none; }
  summary::before { content: "▶ "; font-size: 0.65rem; }
  details[open] summary::before { content: "▼ "; }
  summary:hover { color: #444; }
  .preview { display: inline; }
  .content { font-size: 0.9rem; margin-top: 0.75rem; }
  .content p { margin: 0.5rem 0; }
  .content a { color: #555; }
  .content iframe { display: block; width: 100%; max-width: 100%; border: none; }
  .algorithm { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid #eee; font-size: 0.82rem; color: #999; }
  .algorithm p { margin: 0 0 0.6rem; }
  .algorithm details { margin-top: 0.5rem; }
  .algorithm summary { font-size: 0.82rem; color: #999; cursor: pointer; list-style: none; }
  .algorithm summary::-webkit-details-marker { display: none; }
  .algorithm summary::before { content: "▶ "; font-size: 0.6rem; }
  .algorithm details[open] summary::before { content: "▼ "; }
  .algorithm ol { margin: 0.5rem 0 0.5rem 1.25rem; padding: 0; }
  .algorithm li { margin-bottom: 0.2rem; }
  .algorithm code { background: #f5f5f5; padding: 0.1rem 0.3rem; border-radius: 3px; font-size: 0.8rem; color: #555; }
  .comics { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 2px solid #eee; }
  .comics .section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #bbb; margin-bottom: 1rem; }
  .comic-item { padding: 0.75rem 0; border-bottom: 1px solid #f0f0f0; }
  .comic-item:last-child { border-bottom: none; }
  .comic-item h2 { font-size: 0.95rem; margin: 0 0 0.2rem; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #eee; font-size: 0.8rem; color: #bbb; }
</style>
</head>
<body>
<nav>
  <a href="index.html">all briefings</a>
  {% if prev_date %} · <a href="{{ prev_date }}.html">← {{ prev_date }}</a>{% endif %}
</nav>
<h1>d<strong>ai</strong>ly</h1>
<div class="date">{{ date_str }}</div>

{% for item in ranked %}
<div class="item">
  <div class="rank">
    <span class="rank-pos">{{ item.rank }}</span>
    {% if item.score is not none %}<span class="rank-score">{{ item.score | int }}/10</span>{% endif %}
  </div>
  <div class="item-body">
    <h2><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h2>
    <div class="meta">
      <span class="source">{{ item.source }}</span>
      · <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">original →</a>
    </div>
    {% if item.content %}
    <details>
      <summary><span class="preview">{{ item.content | striptags | truncate(200, end='…') }}</span></summary>
      {# content is pre-processed HTML from RSS/trafilatura — sources are a
         fixed trusted allow-list configured by the site owner. #}
      <div class="content">{{ item.content | safe }}</div>
    </details>
    {% endif %}
  </div>
</div>
{% endfor %}

{% if scoring_info %}
<div class="algorithm">
  <p>
    Top {{ scoring_info.top_n }} items from {{ scoring_info.sources | length }} sources, scored 1–10 by
    <code>{{ scoring_info.model }}</code> on relevance to my interests.
    At most {{ scoring_info.max_per_source }} items per source.
  </p>
  <details>
    <summary>Scoring categories &amp; sources</summary>
    <ol>
      {% for cat in scoring_info.categories %}
      <li>{{ cat }}</li>
      {% endfor %}
    </ol>
    <p>Sources: {{ scoring_info.sources | join(", ") }}</p>
  </details>
</div>
{% endif %}

{% if comics %}
<div class="comics">
  <div class="section-label">Comics</div>
  {% for item in comics %}
  <div class="comic-item">
    <h2>{{ item.title }}</h2>
    <div class="meta">
      <span class="source">{{ item.source }}</span>
      · <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">view →</a>
    </div>
    {% if item.content %}
    {# content is pre-processed HTML from RSS/trafilatura — sources are a
       fixed trusted allow-list configured by the site owner. #}
    <div class="content">{{ item.content | safe }}</div>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

<footer>{{ date_str }}</footer>
</body>
</html>
